<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:l="sap.ui.layout"
>
    <Dialog
        id="rejectDialog"
        title="Conferma"
        contentWidth="450px"
    >
        <content>
            <Text
                text="Inserire la motivazione del respingimento."
                class="sapUiSmallMarginTop sapUiSmallMarginBegin"
            />

            <Label
                required="true"
                labelFor="rejectReasonTextArea"
            />

            <TextArea
                id="rejectReasonTextArea"
                width="90%"
                maxLength="255"
                rows="5"
                placeholder="Inserisci qui la motivazione"
                required="true"
                class="sapUiSmallMargin"
            />
        </content>

        <buttons>
            <Button
                text="Conferma"
                type="Accept"
            />

            <Button text="Annulla" />
        </buttons>
    </Dialog>
</core:FragmentDefinition>
