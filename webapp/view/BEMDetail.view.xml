<mvc:View controllerName="sap.m.bem.controller.BEMDetail"
    xmlns:mvc="sap.ui.core.mvc" displayBlock="true"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.ui.layout.form"
    xmlns:t="sap.ui.table"
    xmlns:fb="sap.ui.comp.filterbar"
    xmlns:c="sap.suite.ui.commons"
    xmlns:svm="sap.ui.comp.smartvariants">

   <Page id="p" title="{i18n>TitoloAvanzamento}">

        <VBox id="messageContainer" visible="false">
            <MessageStrip
                id="messageStrip"
                text="Selezionare una posizione"
                type="Warning"
                showIcon="true"
                showCloseButton="false"
                class="sapUiMediumMarginBottom">
            </MessageStrip>
        </VBox>

        <headerContent>
            <Toolbar style="Clear">
                <ToolbarSpacer />
                <Button text="Salva" type="Accept" press="onPressButton1" />
                <Button text="Allegati" type="Default" press="onPressButton2" />
                <Button text="Chiudi" type="Reject" press=".onPressButton3" ariaHasPopup="Dialog" />
            </Toolbar>
        </headerContent>
   
    <c:ProcessFlow id="processflow" scrollable="false" wheelZoomable="false" nodes="{/nodes}" lanes="{/lanes}" class="sapUiSmallMargin">
			<c:nodes>
				<c:ProcessFlowNode laneId="{lane}" nodeId="{id}" state="{state}" children="{children}" />
			</c:nodes>
			<c:lanes>
				<c:ProcessFlowLaneHeader laneId="{id}" iconSrc="{icon}" text="{label}" position="{position}" />
			</c:lanes>
	</c:ProcessFlow>
   
    <VBox class="sapUiSmallMargin">
                    
        <f:SimpleForm
            id="SimpleForm1"
            editable="false"
            layout="ResponsiveGridLayout"
            title="Dettagli Consultivazione"
            labelSpanXL="4"
            labelSpanL="4"
            labelSpanM="12"
            labelSpanS="12"
            adjustLabelSpan="false"
            emptySpanXL="0"
            emptySpanL="0"
            emptySpanM="0"
            emptySpanS="0"
            columnsXL="3"
            columnsL="2"
            columnsM="1"
            singleContainerFullSize="false">

            <f:content>
                <!-- Prima sezione -->
                <Label text="Numero Consuntivazione" />
                <Text text="{NumeroConsuntivazione}" />

                <Label text="Data fine lavori" />
                <DatePicker value="{DataFineLavori}" editable="true" />

                <Label text="Data Registrazione" />
                <DatePicker value="{DataRegistrazione}" editable="true" />

                <Label text="Società" />
                <Text text="{Societa}" />

                <Label text="Stato Consuntivazione" />
                <Text text="{StatoConsuntivazione}" />

                <Label text="Acquisito il" />
                <Text text="{AcquisitoIl}" />

                <Label text="Autore Acquisizione" />
                <Text text="{AutoreAcquisizione}" />

                <Label text="Tipo Consuntivazione" />
                <Text text="{TipoConsuntivazione}" />

                <!-- Seconda sezione -->
                <core:Title text="Dettagli Commessa" />
                <Label text="Commessa" />
                <Text text="{Commessa}" />

                <Label text="Descrizione" />
                <Text text="{Descrizione}" />

                <Label text="Importo Totale" />
                <Text text="{ImportoTotale}" />

                <Label text="Ordinato da" />
                <Text text="{OrdinatoDa}" />

                <Label text="Area" />
                <Text text="{Area}" />

                <Label text="Sotto-Area" />
                <Text text="{SottoArea}" />

                <!-- Terza sezione -->
                <core:Title text="Dettagli Fornitore" />
                <Label text="Fornitore" />
                <Text text="{Fornitore}" />

                <Label text="Ragione Sociale" />
                <Text text="{RagioneSociale}" />

                <Label text="Bolla Consegna" />
                <Input value="{BollaConsegna}" editable="true" />

                <Label text="Lettera Vettura" />
                <Input value="{LetteraVettura}" editable="true" />

                <Label text="Gruppo Acquisti" />
                <Text text="{GruppoAcquisti}" />

                <Label text="Numero ODA" />
                <Text text="{NumeroODA}" />
            </f:content>
        </f:SimpleForm>
    </VBox>
		<content>
            <VBox class="sapUiSmallMargin">
                    <Toolbar>
                        <Title text="Vista"/>
                        <ToolbarSpacer></ToolbarSpacer>
                        <Button text="Importa da Ordine di Acquisto" type="Accept" press="onOpenFragment" />
                        <Button text="Dettaglio Ticket" type="Emphasized" press="onPressButton5" />
                        <Button text="Azzera Importi" type="Attention" press="onPressButton6"/>
                        <Button text="Cancella Posizione" type="Reject" press="onPressButton7"/>
                    </Toolbar>

                <t:Table id="BEMDetailTable" rows="{bemModel>/BemTableDetail}" selectionMode="Single" rowMode="Auto">
                    <t:columns>
                        <t:Column width="11rem">
                            <Label text="Testo breve materiale" />
                            <t:template>
                                <Text text="{bemModel>TestoBreveMateriale}" wrapping="false" />
                            </t:template>
                        </t:Column>
                        <t:Column width="11rem">
                            <Label text="Elemento WBS" />
                            <t:template>
                                <Text text="{bemModel>ElementoWBS}" wrapping="false" />
                            </t:template>
                        </t:Column>
                        <t:Column width="11rem">
                            <Label text="Quantità" />
                            <t:template>
                                <Text text="{bemModel>Quantita}" wrapping="false" />
                            </t:template>
                        </t:Column>
                        <t:Column width="11rem">
                            <Label text="Imp. divisa int." />
                            <t:template>
                                <Text text="{bemModel>ImpDivisaInt}" wrapping="false" />
                            </t:template>
                        </t:Column>
                        <t:Column width="11rem">
                            <Label text="UMO" />
                            <t:template>
                                <Text text="{bemModel>UMO}" wrapping="false" />
                            </t:template>
                        </t:Column>
                        <t:Column width="11rem">
                            <Label text="Prz. netto" />
                            <t:template>
                                <Text text="{bemModel>PrzNetto}" wrapping="false" />
                            </t:template>
                        </t:Column>
                        <t:Column width="11rem">
                            <Label text="Riferimento" />
                            <t:template>
                                <Text text="{bemModel>Riferimento}" wrapping="false" />
                            </t:template>
                        </t:Column>
                        <t:Column width="11rem">
                            <Label text="Anno Stz." />
                            <t:template>
                                <Text text="{bemModel>AnnoStz}" wrapping="false" />
                            </t:template>
                        </t:Column>
                        <t:Column width="11rem">
                            <Label text="% Stz." />
                            <t:template>
                                <Text text="{bemModel>PercentStz}" wrapping="false" />
                            </t:template>
                        </t:Column>
                        <t:Column width="11rem">
                            <Label text="N. Doc. Stz." />
                            <t:template>
                                <Text text="{bemModel>NumeroDocStz}" wrapping="false" />
                            </t:template>
                        </t:Column>
                        <t:Column width="11rem">
                            <Label text="Pos. Stz." />
                            <t:template>
                                <Text text="{bemModel>PosStz}" wrapping="false" />
                            </t:template>
                        </t:Column>
                        <t:Column width="11rem">
                            <Label text="Altri doc" />
                            <t:template>
                                <Text text="{bemModel>AltriDoc}" wrapping="false" />
                            </t:template>
                        </t:Column>
                        <t:Column width="11rem">
                            <Label text="Stz. Finale" />
                            <t:template>
                                <Text text="{bemModel>StzFinale}" wrapping="false" />
                            </t:template>
                        </t:Column>
                        <t:Column width="11rem">
                            <Label text="Importo stanziamento" />
                            <t:template>
                                <Text text="{bemModel>ImportoStanziamento}" wrapping="false" />
                            </t:template>
                        </t:Column>
                        <t:Column width="11rem">
                            <Label text="Sospeso Residuo" />
                            <t:template>
                                <Text text="{bemModel>SospesoResiduo}" wrapping="false" />
                            </t:template>
                        </t:Column>
                        <t:Column width="11rem">
                            <Label text="Osservazioni Stanziamento" />
                            <t:template>
                                <Text text="{bemModel>OsservazioniStanziamento}" wrapping="false" />
                            </t:template>
                        </t:Column>
                        <t:Column width="11rem">
                            <Label text="Codice CUP" />
                            <t:template>
                                <Text text="{bemModel>CodiceCUP}" wrapping="false" />
                            </t:template>
                        </t:Column>
                        <t:Column width="11rem">
                            <Label text="Codice CIG" />
                            <t:template>
                                <Text text="{bemModel>CodiceCIG}" wrapping="false" />
                            </t:template>
                        </t:Column>
                        <t:Column width="11rem">
                            <Label text="Descrizione CIG" />
                            <t:template>
                                <Text text="{bemModel>DescrizioneCIG}" wrapping="false" />
                            </t:template>
                        </t:Column>
                        <t:Column width="11rem">
                            <Label text="Dettaglio Ticket" />
                            <t:template>
                                <Text text="{bemModel>DettaglioTicket}" wrapping="false" />
                            </t:template>
                        </t:Column>
                        <t:Column width="11rem">
                            <Label text="Sede Tecnica" />
                            <t:template>
                                <Text text="{bemModel>SedeTecnica}" wrapping="false" />
                            </t:template>
                        </t:Column>
                        <t:Column width="11rem">
                            <Label text="Descrizione Sede Tecnica" />
                            <t:template>
                                <Text text="{bemModel>DescrizioneSedeTecnica}" wrapping="false" />
                            </t:template>
                        </t:Column>
                    </t:columns>
                </t:Table>


            </VBox>
      </content>


   </Page>

   
</mvc:View>