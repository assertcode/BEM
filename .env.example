# ============================================================
# BTP Cloud Foundry – Deployment credentials for BEM
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control (it is in .gitignore).
# ============================================================

# Your BTP / CF account credentials
CF_USER=your-email@example.com
CF_PASSWORD=your-password

# API endpoint (do not change unless the landscape changes)
CF_API=https://api.cf.eu10-004.hana.ondemand.com

# Quality environment
CF_ORG_QUALITY=Rekeep-ECC-CF-TESTOrg
CF_SPACE_QUALITY=TEST

# Production environment
CF_ORG_PROD=Rekeep S.p.A._rekeep-s-p-a-ecc-cf-prod
CF_SPACE_PROD=TARGET
